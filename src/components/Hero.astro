---
const { hero, company } = Astro.props;
---

<section id="top" class="relative overflow-hidden border-b border-white/[0.08] pt-[68px]">
  <div class="absolute inset-0">
    <img src={hero.image.src} alt={hero.image.alt} class="h-full w-full object-cover object-[70%_center] opacity-75" loading="eager" decoding="async" fetchpriority="high" />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,#020406_0%,rgba(2,4,6,0.98)_29%,rgba(2,4,6,0.62)_52%,rgba(2,4,6,0.22)_73%,rgba(2,4,6,0.7)_100%)]"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#020406] to-transparent"></div>
  </div>

  <div class="section-shell relative flex min-h-[520px] flex-col justify-center py-12 lg:min-h-[560px]">
    <div class="max-w-[560px]">
      <p class="font-display text-[34px] font-semibold uppercase leading-none tracking-[0.11em] text-white sm:text-[42px]">{hero.eyebrow}</p>
      <h1 class="mt-4 font-display text-[58px] font-bold uppercase leading-[0.86] tracking-[0.06em] text-[#d8a139] sm:text-[76px] lg:text-[88px]">{hero.titleAccent}</h1>
      <p class="mt-4 font-display text-[32px] font-semibold uppercase leading-tight tracking-[0.08em] text-white sm:text-[42px]">{hero.titleRest}</p>
      <p class="mt-7 max-w-[440px] text-[15px] leading-7 text-slate-300">{hero.subtitle}</p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href={company.phoneHref} class="button-gold">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 3v4M17 3v4M4 9h16" stroke-linecap="round" />
            <rect x="4" y="5" width="16" height="16" rx="2" />
            <path d="M8 13h3M8 17h6" stroke-linecap="round" />
          </svg>
          Записаться на услуги
        </a>
      </div>
    </div>

    <div id="about" class="mt-8 grid max-w-[660px] gap-5 sm:grid-cols-3">
      {hero.stats.map((item) => (
        <div class="flex items-center gap-3">
          <span class="gold-icon text-base" aria-hidden="true">◎</span>
          <div>
            <div class="text-[13px] font-bold text-white">{item.title}</div>
            <div class="mt-0.5 text-[11px] text-slate-400">{item.text}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

