---
const { services } = Astro.props;
---

<section id="services" class="section-space">
  <div class="section-shell">
    <div class="max-w-3xl">
      <span class="eyebrow">Услуги</span>
      <h2 class="section-title mt-4">Продуманные решения для внешнего вида и комфорта автомобиля</h2>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-2">
      {
        services.map((service) => (
          <article class="premium-card flex h-full flex-col rounded-[30px] p-6 sm:p-8">
            <div class="flex items-start justify-between gap-4">
              <h3 class="max-w-sm text-2xl font-semibold text-white">{service.title}</h3>
              <span class="rounded-full border border-accent/25 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-accent-soft">
                {service.price}
              </span>
            </div>
            <p class="mt-4 flex-1 text-sm leading-7 text-slate-300">{service.description}</p>
            <div class="mt-6">
              <a href="#contact-form" class="button-secondary">Записаться</a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
