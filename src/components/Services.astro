---
const { services } = Astro.props;
---

<section id="services" class="section-shell pb-3 pt-5">
  <div class="section-heading">
    <div class="gold-line"></div>
    <h2>Наши услуги</h2>
    <div class="gold-line"></div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {services.map((service) => (
      <article class="panel-border group overflow-hidden rounded-md">
        <div class="relative h-[190px] overflow-hidden sm:h-[210px]">
          <img src={service.image} alt={service.alt} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#030507] via-[#030507]/25 to-transparent"></div>
        </div>
        <div class="flex min-h-[126px] gap-5 p-7">
          <span class="gold-icon mt-1 text-lg" aria-hidden="true">◇</span>
          <div>
            <h3 class="font-display text-[20px] font-semibold uppercase tracking-[0.08em] text-white">{service.title}</h3>
            <p class="mt-2 text-[13px] leading-6 text-slate-400">{service.description}</p>
              <p class="mt-4 text-[17px] font-extrabold text-white">{service.price}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>



