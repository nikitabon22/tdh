---
const { company } = Astro.props;
---

<footer class="border-t border-white/[0.08] py-8">
  <div class="section-shell flex flex-col items-center justify-between gap-4 text-center md:flex-row md:text-left">
    <div class="font-display text-sm uppercase tracking-[0.28em] text-slate-500">
      Доверьте свой автомобиль нам!
    </div>
    <div class="text-sm text-slate-500">
      {company.name} · {company.phone}
    </div>
  </div>
</footer>
