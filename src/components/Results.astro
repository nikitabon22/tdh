---
const { results } = Astro.props;
---

<section class="section-space">
  <div class="section-shell">
    <div class="premium-card overflow-hidden rounded-[36px]">
      <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="border-b border-white/[0.08] bg-white/[0.03] p-8 sm:p-10 lg:border-b-0 lg:border-r">
          <span class="eyebrow">Результат</span>
          <h2 class="section-title mt-4">Эффект, который заметен сразу</h2>
          <p class="mt-5 text-sm leading-7 text-slate-300 sm:text-base">
            Мы работаем так, чтобы автомобиль выглядел чище, свежее и выразительнее уже с
            первого взгляда.
          </p>
        </div>

        <div class="grid gap-px bg-white/[0.08] sm:grid-cols-2">
          {
            results.map((item) => (
              <article class="bg-canvas/90 p-6 sm:p-8">
                <div class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-soft">
                  До / после
                </div>
                <h3 class="mt-4 text-2xl font-semibold text-white">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

