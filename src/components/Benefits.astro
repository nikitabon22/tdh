---
const { benefits } = Astro.props;
---

<section id="benefits" class="section-shell py-2">
  <div class="section-heading">
    <div class="gold-line"></div>
    <h2>Почему выбирают нас?</h2>
    <div class="gold-line"></div>
  </div>

  <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
    {benefits.map((item) => (
      <article class="flex gap-4 border-l border-white/[0.1] pl-5 first:border-l-0 first:pl-0 md:first:border-l md:first:pl-5 xl:first:border-l-0 xl:first:pl-0">
        <span class="gold-icon text-lg" aria-hidden="true">○</span>
        <div>
          <h3 class="font-display text-[15px] font-semibold uppercase tracking-[0.08em] text-white">{item.title}</h3>
          <p class="mt-2 text-[12px] leading-6 text-slate-400">{item.text}</p>
        </div>
      </article>
    ))}
  </div>
</section>
