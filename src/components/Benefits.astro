---
const { benefits } = Astro.props;
---

<section id="benefits" class="section-space">
  <div class="section-shell">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="eyebrow">Преимущества</span>
        <h2 class="section-title mt-4">Сервис, в котором важна каждая деталь</h2>
      </div>
      <p class="section-copy">
        Премиальный уход строится не только на эффектном результате, но и на точности,
        чистоте процессов и доверии к мастеру.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {
        benefits.map((item, index) => (
          <article class="premium-card h-full rounded-[28px] p-6 sm:p-7">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-accent/[0.12] text-sm font-bold text-accent-soft">
              0{index + 1}
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

