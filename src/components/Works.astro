---
const { works } = Astro.props;
---

<section id="works" class="section-shell pb-3 pt-6">
  <div class="section-heading">
    <div class="gold-line"></div>
    <h2>Выполненные работы</h2>
    <div class="gold-line"></div>
  </div>

  <div class="grid gap-5 lg:grid-cols-2">
    {works.map((work) => {
      const images = work.images?.length ? work.images : [work.image || "https://images.unsplash.com/photo-1552519507-da3b142c6e3d?auto=format&fit=crop&w=900&q=85"].filter(Boolean);
      return (
        <article class="panel-border overflow-hidden rounded-md">
          <div class="relative">
            <div class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth">
              {images.map((image) => (
                <a href={work.url} target="_blank" rel="noopener noreferrer" class="relative h-[300px] min-w-full snap-start overflow-hidden sm:h-[360px]">
                  <img
                    src={image}
                    alt={work.alt}
                    class="h-full w-full object-cover transition duration-500 hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#020406] via-transparent to-transparent"></div>
                </a>
              ))}
            </div>

            <div class="absolute left-5 top-5 rounded-sm border border-[#b9812b]/60 bg-[#020406]/75 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-[#d8a139]">
              {work.category}
            </div>

            {images.length > 1 && (
              <div class="absolute bottom-5 right-5 rounded-sm border border-white/[0.12] bg-[#020406]/75 px-3 py-2 text-[11px] uppercase tracking-[0.16em] text-slate-300">
                {images.length} фото
              </div>
            )}
          </div>

          <div class="p-6">
            <a href={work.url} target="_blank" rel="noopener noreferrer" class="font-display text-2xl font-semibold uppercase tracking-[0.08em] text-white transition hover:text-[#d8a139]">
              {work.title}
            </a>
            {work.description && (
              <p class="mt-4 line-clamp-5 whitespace-pre-line text-sm leading-7 text-slate-300">
                {work.description}
              </p>
            )}
            <a href={work.url} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex text-xs font-bold uppercase tracking-[0.2em] text-[#d8a139] hover:text-[#f0bd56]">
              Смотреть пост VK
            </a>
          </div>
        </article>
      );
    })}
  </div>
</section>


