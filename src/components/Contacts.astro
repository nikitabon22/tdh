---
const { company } = Astro.props;
---

<section id="contacts" class="section-shell pb-9 pt-8">
  <div class="grid gap-8 lg:grid-cols-[0.31fr_0.69fr]">
    <div class="pt-1">
      <h2 class="font-display text-[30px] font-semibold uppercase leading-none tracking-[0.22em] text-[#d8a139] sm:text-[34px]">
        Мы находимся
      </h2>

      <div class="mt-10 flex items-start gap-5">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#b9812b]/80 text-[#d8a139]">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" />
            <circle cx="12" cy="10" r="2.2" />
          </svg>
        </span>
        <div>
          <p class="text-[27px] font-extrabold leading-tight text-white">г. Горловка</p>
          <p class="mt-2 text-[27px] font-extrabold leading-tight text-white">{company.shortAddress}</p>
        </div>
      </div>

      <p class="mt-8 max-w-[330px] text-[16px] leading-8 text-slate-200">
        Ориентир: на территории находится бывшая заправка Extra
      </p>

      <div class="mt-9 grid grid-cols-2 gap-3">
        <a href={company.phoneHref} class="inline-flex h-12 items-center justify-center gap-3 rounded-[3px] border border-[#b9812b]/80 px-5 text-sm font-bold text-white transition hover:bg-[#b9812b]/15">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.32 1.77.6 2.61a2 2 0 0 1-.45 2.11L8 9.7a16 16 0 0 0 6.3 6.3l1.26-1.26a2 2 0 0 1 2.11-.45c.84.28 1.71.48 2.61.6A2 2 0 0 1 22 16.92Z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Связаться с нами
        </a>
        <a href={company.telegramHref} class="inline-flex h-12 items-center justify-center rounded-[3px] border border-[#b9812b]/80 px-5 text-sm font-bold text-white transition hover:bg-[#b9812b]/15">
          Telegram
        </a>
      </div>
    </div>

    <div class="relative min-h-[300px] overflow-hidden rounded-[3px] border border-white/[0.08] bg-[#101722]">
      <iframe
        title="Карта проезда к TDH Studio"
        src="https://yandex.ru/map-widget/v1/?text=%D0%93%D0%BE%D1%80%D0%BB%D0%BE%D0%B2%D0%BA%D0%B0%2C%20%D1%83%D0%BB.%20%D0%9E%D1%81%D1%82%D0%B0%D0%BF%D0%B5%D0%BD%D0%BA%D0%BE%2045%D0%90&z=16"
        class="absolute inset-0 h-full w-full border-0 grayscale invert-[0.9] hue-rotate-180 contrast-125 brightness-[0.65]"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(2,4,6,0.1),rgba(2,4,6,0.2))]"></div>
      <div class="pointer-events-none absolute left-[48%] top-[56%] -translate-x-1/2 -translate-y-full">
        <div class="relative flex h-14 w-14 items-center justify-center rounded-full bg-[#d8a139] text-[#050505] shadow-[0_0_35px_rgba(216,161,57,0.55)]">
          <span class="absolute h-20 w-20 rounded-full border border-[#d8a139]/35"></span>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 21h16" stroke-linecap="round" />
            <path d="M6 21V8l6-4 6 4v13" stroke-linejoin="round" />
            <path d="M9 21v-6h6v6M9 10h.01M12 10h.01M15 10h.01" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="mx-auto h-0 w-0 border-l-[10px] border-r-[10px] border-t-[14px] border-l-transparent border-r-transparent border-t-[#d8a139]"></div>
      </div>
      <div class="absolute bottom-5 left-5 right-5 flex flex-col gap-3 sm:left-auto sm:right-5 sm:w-[286px]">
        <div class="rounded-[3px] border border-white/[0.1] bg-[#05080c]/90 p-4 shadow-[0_18px_45px_rgba(0,0,0,0.45)] backdrop-blur-md">
          <p class="text-base font-extrabold text-white">{company.shortAddress}</p>
          <p class="mt-1 text-sm text-slate-300">бывшая заправка Extra</p>
        </div>
        <a href={company.mapsHref} class="inline-flex h-11 items-center justify-center rounded-[3px] border border-[#b9812b]/80 bg-[#05080c]/90 px-4 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-100 transition hover:bg-[#b9812b]/15">
          Открыть карту
        </a>
      </div>
    </div>
  </div>
</section>

