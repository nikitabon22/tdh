---
const { company } = Astro.props;
---

<section id="contacts" class="section-shell pb-9 pt-8">
  <div class="grid gap-8 lg:grid-cols-[0.31fr_0.69fr]">
    <div class="pt-1">
      <h2 class="font-display text-[30px] font-semibold uppercase leading-none tracking-[0.22em] text-[#d8a139] sm:text-[34px]">
        Мы находимся
      </h2>

      <div class="mt-10 flex items-start gap-5">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#b9812b]/80 text-[#d8a139]">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" />
            <circle cx="12" cy="10" r="2.2" />
          </svg>
        </span>
        <div>
          <p class="text-[27px] font-extrabold leading-tight text-white">г. Горловка</p>
          <p class="mt-2 text-[27px] font-extrabold leading-tight text-white">{company.shortAddress}</p>
        </div>
      </div>

      <p class="mt-8 max-w-[330px] text-[16px] leading-8 text-slate-200">
        Ориентир: на территории находится бывшая заправка Extra
      </p>

      <div class="mt-9 grid grid-cols-2 gap-3">
        <a href={company.phoneHref} class="inline-flex h-12 items-center justify-center gap-3 rounded-[3px] border border-[#b9812b]/80 px-5 text-sm font-bold text-white transition hover:bg-[#b9812b]/15">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.32 1.77.6 2.61a2 2 0 0 1-.45 2.11L8 9.7a16 16 0 0 0 6.3 6.3l1.26-1.26a2 2 0 0 1 2.11-.45c.84.28 1.71.48 2.61.6A2 2 0 0 1 22 16.92Z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Связаться с нами
        </a>
        <a href={company.telegramHref} class="inline-flex h-12 items-center justify-center rounded-[3px] border border-[#b9812b]/80 px-5 text-sm font-bold text-white transition hover:bg-[#b9812b]/15">
          Telegram
        </a>
      </div>
    </div>

    <div class="relative min-h-[360px] overflow-hidden rounded-[3px] border border-white/[0.08] bg-[#101722] shadow-[0_24px_70px_rgba(0,0,0,0.35)]">
      <iframe
        title="Карта проезда к TDH Studio"
        src={company.mapWidgetHref}
        class="absolute inset-0 h-full w-full border-0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#020406]/95 via-[#020406]/60 to-transparent"></div>
      <div class="absolute bottom-5 left-5 right-5 flex flex-col gap-3 sm:left-auto sm:right-5 sm:w-[320px]">
        <div class="rounded-[3px] border border-white/[0.1] bg-[#05080c]/95 p-4 shadow-[0_18px_45px_rgba(0,0,0,0.45)] backdrop-blur-md">
          <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-[#d8a139]">TDH Studio на карте</p>
          <p class="mt-2 text-base font-extrabold text-white">{company.shortAddress}</p>
          <p class="mt-1 text-sm text-slate-300">ориентир: бывшая заправка Extra</p>
        </div>
        <a href={company.mapsHref} target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center justify-center rounded-[3px] border border-[#b9812b]/80 bg-[#05080c]/95 px-4 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-100 transition hover:bg-[#b9812b]/15">
          Открыть карту
        </a>
      </div>
    </div>
  </div>
</section>

